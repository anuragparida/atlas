# atlas-notifier — required env vars
# Copy to .env, fill in, and `chmod 600 .env`. Never commit .env.

# Open WebUI service account API key (Settings → Account → API Keys)
OPENWEBUI_API_KEY=tk_replace_me

# Per-topic publish token from NTFY (see docker/ntfy/README.md)
NTFY_PUBLISH_TOKEN=tk_replace_me

# Required: explicit Open WebUI user id. The notifier's auto-discovery via
# GET /api/v1/auths/me/ is broken on the current Open WebUI build, so set
# this explicitly. Match the topic name used in docker/ntfy/README.md.
ATLAS_USER_ID=anurag

# Optional: override service hosts (defaults match the compose network)
# OPENWEBUI_BASE_URL=http://openwebui:8080
# NTFY_BASE_URL=http://ntfy:8090

# Optional: tuning
# ATLAS_POLL_INTERVAL=3          # seconds between REST polls
# ATLAS_SHUTDOWN_GRACE=5         # seconds to drain in-flight publishes
# ATLAS_HEALTH_HOST=127.0.0.1    # bind healthz to localhost only
# ATLAS_HEALTH_PORT=18080
# ATLAS_NTFY_TIMEOUT=2.0        # publish request timeout
# ATLAS_STATE_DIR=/var/lib/atlas-notifier
